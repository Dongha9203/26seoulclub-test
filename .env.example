# 민감정보 — 이 파일은 커밋해도 됩니다 (플레이스홀더만 있음)
# 실제 값은 .env 파일에 채우세요 (.env는 .gitignore에 포함되어 커밋되지 않습니다)

NOTION_API_TOKEN={{NOTION_API_TOKEN}}
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}
VOYAGE_API_KEY={{VOYAGE_API_KEY}}

# Supabase Postgres 연결 문자열 (Transaction Pooler, 6543 포트 — 서버리스 환경 권장)
# Supabase 대시보드 > Settings > Database > Connection string > Transaction pooler
SUPABASE_DB_URL=postgresql://postgres.{{PROJECT_REF}}:{{DB_PASSWORD}}@{{POOLER_HOST}}:6543/postgres?sslmode=require

# 4단계: 운영 대시보드 JWT 서명 키 (배포 환경마다 새로 발급 — python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY={{JWT_SECRET_KEY}}
